#!/usr/bin/env bash
#
# pre-push: fast fmt/clippy gate + AI review for openHiTLS-rs.
#
# Two stages run before a push is allowed:
#   1. Fast local presubmit — `cargo fmt --check` + `cargo clippy`. In a
#      trunk-based workflow there is no PR to catch a broken build, so
#      this gate keeps the trunk green by construction (~40s warm).
#   2. AI review — an external-auditor-framed `claude -p` against the
#      diff being pushed, aborting on a critical finding or on signs the
#      reviewer didn't actually engage with the change.
# The pre-push hook is the only natural place to land both in a
# trunk-based workflow (no PRs on the remote).
#
# Install once per clone (covers all worktrees via shared config):
#
#     git config core.hooksPath .githooks
#
# Skip a single push:
#
#     SKIP_PRESUBMIT=1 git push ...   # skip the fmt/clippy gate only
#     SKIP_AI_REVIEW=1 git push ...   # skip the AI review only
#     git push --no-verify ...        # git-native bypass (skips both)
#
# Objectivity design (relative to "stock" Claude Code review):
#
#   --bare ............ disables auto-loading of CLAUDE.md / DEV_LOG.md
#                       / skills / memory, so the reviewer cannot be
#                       steered by the project's own narrative about
#                       why a change exists. Everything the reviewer
#                       needs is in the prompt below.
#   --model sonnet .... use a different model family than the one most
#                       likely authoring the change (Opus on this
#                       machine). Cross-model review breaks single-model
#                       blind spots and RLHF self-affinity.
#   external auditor framing
#                       prompt sets up the reviewer as an independent
#                       auditor with no stake in shipping, explicitly
#                       discounting any narrative in the diff itself
#                       (commit messages, code comments asserting
#                       "this is safe").
#   evidence requirement
#                       every CRITICAL / HIGH finding MUST cite
#                       [file:line]; vague findings are dropped.
#   diff-read proof ... the model must run `git diff --shortstat` and
#                       quote its output verbatim in a DIFF-SUMMARY:
#                       line. If absent → fail-close.
#   fail-CLOSE on missing VERDICT
#                       reversed from the previous "no verdict = pass"
#                       default. Silence is now blocking, because a
#                       reviewer that didn't bother to engage is not
#                       a signal of safety.
#   audit log ......... every review (input, output, verdict) is
#                       appended to .ai-review-log/ so you can sample
#                       and look for systematic bias.
#
# Behaviour matrix:
#
#     diff is empty / docs-only ........ skip (silent, exit 0)
#     fmt/clippy gate fails ............ abort push (exit 1)
#     `cargo` not in PATH .............. skip gate with warning, continue
#     `claude` CLI not in PATH ......... skip with warning (exit 0)
#     review returns VERDICT: pass ..... allow push (exit 0)
#     review returns VERDICT: block .... abort push (exit 1)
#     review returns NO VERDICT ........ abort push (exit 1, fail-CLOSE)
#     DIFF-SUMMARY line missing ........ abort push (exit 1)
#     `claude` invocation errors ....... skip with warning (exit 0)
#                                        (genuine tool/network failure
#                                        shouldn't make push impossible)

set -uo pipefail

if [ "${SKIP_AI_REVIEW:-}" = "1" ]; then
    echo "[ai-review] SKIP_AI_REVIEW=1 set, skipping." >&2
    exit 0
fi

if ! command -v claude >/dev/null 2>&1; then
    echo "[ai-review] 'claude' CLI not in PATH, skipping." >&2
    echo "[ai-review] Install: https://docs.claude.com/en/docs/claude-code/setup" >&2
    exit 0
fi

# Read pre-push tuples from stdin: <local_ref> <local_sha> <remote_ref> <remote_sha>
local_sha=""
remote_sha=""
zero="0000000000000000000000000000000000000000"
while read -r _local_ref ls _remote_ref rs; do
    if [ "$ls" = "$zero" ]; then
        # Branch deletion — nothing to review.
        continue
    fi
    local_sha="$ls"
    remote_sha="$rs"
    break
done

if [ -z "$local_sha" ]; then
    exit 0
fi

# New branch on the remote → diff against origin/main.
if [ "$remote_sha" = "$zero" ] || [ -z "$remote_sha" ]; then
    git fetch --quiet origin main 2>/dev/null || true
    if git rev-parse --verify --quiet origin/main >/dev/null; then
        base="$(git rev-parse origin/main)"
    else
        base="$(git hash-object -t tree /dev/null)"
    fi
else
    base="$remote_sha"
fi

changed="$(git diff --name-only "$base..$local_sha" 2>/dev/null || true)"
if [ -z "$changed" ]; then
    exit 0
fi

n_files="$(printf '%s\n' "$changed" | wc -l | tr -d ' ')"

# Classify the diff by path against the literal crate directory layout
# in CLAUDE.md. Update this when adding new crypto-sensitive crates.
crypto_paths='^crates/(hitls-crypto|hitls-bignum|hitls-tls|hitls-pki|hitls-auth)/'
docs_only_paths='(^docs/|^tests/tlsfuzzer/xfail|\.(md|txt|yml|yaml|toml|lock)$)'

has_crypto=0
has_other_code=0
has_only_docs=1

while IFS= read -r f; do
    [ -z "$f" ] && continue
    if printf '%s\n' "$f" | grep -qE "$crypto_paths"; then
        has_crypto=1
        has_only_docs=0
    elif printf '%s\n' "$f" | grep -qE '\.(rs|sh)$'; then
        has_other_code=1
        has_only_docs=0
    elif ! printf '%s\n' "$f" | grep -qE "$docs_only_paths"; then
        has_other_code=1
        has_only_docs=0
    fi
done <<< "$changed"

if [ "$has_only_docs" = "1" ]; then
    echo "[ai-review] only docs/config changed ($n_files file(s)), skipping." >&2
    exit 0
fi

# ── Stage 1: fast local presubmit (fmt + clippy) ──────────────────────
# Trunk-based: no PR exists to catch a broken build, so a fmt/clippy
# gate runs here before the (slower) AI review. Keeps the trunk green
# by construction. Bypass with SKIP_PRESUBMIT=1.
if [ "${SKIP_PRESUBMIT:-}" = "1" ]; then
    echo "[presubmit] SKIP_PRESUBMIT=1 set, skipping fmt/clippy gate." >&2
elif ! command -v cargo >/dev/null 2>&1; then
    echo "[presubmit] 'cargo' not in PATH, skipping fmt/clippy gate." >&2
else
    echo "[presubmit] cargo fmt --all --check ..." >&2
    if ! cargo fmt --all -- --check >&2; then
        echo "[presubmit] BLOCK: code is not rustfmt-clean — run 'cargo fmt --all'." >&2
        exit 1
    fi
    echo "[presubmit] cargo clippy --workspace --all-features --all-targets ..." >&2
    if ! cargo clippy --workspace --all-features --all-targets -- -D warnings >&2; then
        echo "[presubmit] BLOCK: clippy reported warnings/errors — fix before pushing." >&2
        exit 1
    fi
    echo "[presubmit] fmt + clippy clean." >&2
fi

# ── Stage 2: AI review ────────────────────────────────────────────────
# Capture the actual --shortstat as a ground truth the model has to
# match (or at least produce something credibly equivalent).
actual_shortstat="$(git diff --shortstat "$base..$local_sha" 2>/dev/null | sed 's/^[[:space:]]*//')"

if [ "$has_crypto" = "1" ]; then
    mode="security"
    IFS= read -r -d '' review_prompt <<'PROMPT' || true
ROLE: You are an independent external security auditor reviewing a
proposed change to a production cryptographic library written in Rust
(openHiTLS-rs). You have NO stake in this change shipping. The author
has motivation to ship and may unconsciously underweight risk; your
role is to find what they missed. Distrust the diff's own narrative —
commit messages, code comments asserting safety, and reasoning in the
change itself are NOT evidence. The only evidence is the code.

CONTEXT (this is everything you need; do not ask for more):
- Project: pure-Rust crypto library + TLS 1.3/1.2/DTLS/TLCP. License MulanPSL-2.0.
- The base SHA is __BASE__, the head SHA is __HEAD__. Both exist in
  the local git history. cwd is the repo root.
- Hard project invariants (CLAUDE.md, not auto-loaded — recited here
  so you have them):
    * Secret-dependent comparisons MUST use `subtle::ConstantTimeEq`,
      never `==` or `!=` on secret material.
    * Secret material (keys, intermediate states) MUST implement
      `Zeroize` and be wiped on drop (`#[derive(Zeroize)]` +
      `#[zeroize(drop)]`).
    * No `unsafe` outside `hitls-bignum` and `hitls-crypto`. The other
      crates (incl. `hitls-tls`, `hitls-pki`, `hitls-auth`, `hitls-cli`,
      `hitls-utils`, `hitls-types`) are safe-only.
    * Cryptographic randomness MUST come from `getrandom`, never `rand`.
    * Library code MUST NOT panic — return `Result<_, CryptoError>`
      instead. No `unwrap()`, `expect()`, direct indexing on
      attacker-controlled inputs, or `panic!` in production paths
      (test/example/bench code is fine).
    * Public APIs return `Result<T, CryptoError>` (or analogous error type).

STEP 1 — prove you read the diff. Run `git diff --shortstat
__BASE__..__HEAD__` and output the result verbatim on a single line
prefixed with `DIFF-SUMMARY:`. If you cannot get any output, output
`DIFF-SUMMARY: <empty>`.

STEP 2 — run `git diff __BASE__..__HEAD__` and read the changed code.
For larger diffs you may also read individual files at HEAD via the
Read tool.

STEP 3 — classify each finding under one of the three severities
below. Every CRITICAL and HIGH finding MUST cite at least one
`[path/to/file.rs:LINE]` location FROM THE DIFF. A finding without a
citation is invalid — drop it.

CRITICAL (each one of these MUST block the push):
  - Variable-time comparison of secret material via `==` / `!=` /
    `slice == slice` / iterator equality. (Note: comparing public
    metadata like cipher suite IDs is fine; the rule applies to keys,
    MACs, signatures, derived secrets, etc.)
  - New secret-bearing struct without `Zeroize` / `#[zeroize(drop)]`,
    OR removal of an existing zeroize.
  - New `unsafe` block introduced in a crate that disallows it
    (anything outside `hitls-bignum` / `hitls-crypto`).
  - New `panic!` / `unwrap()` / `expect()` / direct `[idx]` on
    attacker-controlled input in library production code.
  - Use of the `rand` crate for randomness anywhere (must be
    `getrandom`).
  - Removal or weakening of an existing constant-time codepath.
  - New public API that can panic on adversarial input.
  - Removal of a security-related test or assertion without a written
    replacement.

HIGH (flag with citation; does NOT block):
  - New public API without a `Result` return shape.
  - New dependency added to any `Cargo.toml` (note: needs cargo-vet).
  - TLS / handshake state-machine change without a matching test or
    xfail-list update.
  - New crypto algorithm without an accompanying test vector reference.
  - Logic in a `#[cfg(test)]` block that would alter production
    semantics if the cfg gate were ever removed.
  - Newly-accepted weak primitive (MD5, SHA-1, RC4, DES, RSA<2048,
    ECDSA on weak curves) — flag even if "for interop"; the human
    decides if the interop need outweighs the risk.

INFO (just note, never blocks):
  - Style / naming / minor refactor.

STEP 4 — output a single final block in EXACTLY this format and
output nothing after the closing line of equals signs:

=== AI REVIEW (security mode) ===
DIFF-SUMMARY: <verbatim git diff --shortstat output, or "<empty>">
CRITICAL:
  - <one-line finding> [crates/foo/src/bar.rs:42]
  (or write "none" on its own line if there are no critical findings)
HIGH:
  - <one-line finding> [crates/foo/src/bar.rs:42]
  (or "none")
INFO:
  - <one-line note>
  (or "none")
VERDICT: pass
=================================

Set VERDICT to exactly `block` if and only if at least one CRITICAL
finding is present. If the only findings are HIGH or INFO, VERDICT is
`pass` — the human will read the HIGHs and decide. Do not write
"pass with caveats", "conditional pass", or anything other than `pass`
or `block`.
PROMPT
else
    mode="general"
    IFS= read -r -d '' review_prompt <<'PROMPT' || true
ROLE: You are an independent external auditor reviewing a Rust code
change to openHiTLS-rs (this diff touches non-crypto-core files only).
You have no stake in shipping; the author does. Distrust the diff's
own narrative — only the code is evidence.

CONTEXT: base SHA is __BASE__, head SHA is __HEAD__. cwd is the repo root.

Hard project rules (CLAUDE.md, recited here since not auto-loaded):
  - No `unsafe` outside `hitls-bignum` / `hitls-crypto`.
  - Library code MUST NOT panic — return `Result` instead. No
    `unwrap()` / `expect()` / `panic!` / direct indexing on
    attacker-controlled input in production paths.

STEP 1 — prove you read the diff: run
`git diff --shortstat __BASE__..__HEAD__` and output verbatim on a
line prefixed with `DIFF-SUMMARY:`.

STEP 2 — run `git diff __BASE__..__HEAD__` and read the diff. Read
individual files if needed.

STEP 3 — classify findings. Every CRITICAL / HIGH finding MUST cite
`[file:line]`. Findings without citations are dropped.

CRITICAL (each blocks the push):
  - `panic!` / `unwrap()` / `expect()` / direct indexing on
    attacker-controlled input in library production code.
  - `unsafe` outside the allowed crates.
  - Logic error that would break an existing test (mismatch with the
    test fixtures still committed in the diff).
  - Removal of a test without a written replacement.

HIGH (flag, doesn't block):
  - Missing `Result` error handling on a fallible call (e.g., bare
    `.parse()`, `.try_into()` discarded).
  - Public API regression (signature change without an explicit reason).
  - New dependency in Cargo.toml.

INFO (just note):
  - Style / naming.

STEP 4 — output exactly:

=== AI REVIEW (general mode) ===
DIFF-SUMMARY: <verbatim git diff --shortstat output, or "<empty>">
CRITICAL:
  - <finding> [file:line]
  (or "none")
HIGH:
  - <finding> [file:line]
  (or "none")
INFO:
  - <finding>
  (or "none")
VERDICT: pass
================================

VERDICT is `block` iff at least one CRITICAL is present. Otherwise
`pass`. No third option. Output nothing after the closing equals line.
PROMPT
fi

# Substitute the real SHAs.
review_prompt="${review_prompt//__BASE__/$base}"
review_prompt="${review_prompt//__HEAD__/$local_sha}"

# --bare requires ANTHROPIC_API_KEY (it refuses to read OAuth/keychain).
# When the key is set, use it for full context isolation: no CLAUDE.md,
# DEV_LOG, skill, or memory bleed into the reviewer. When the key is
# missing, fall back to a non-bare run (still gets the prompt-level
# defenses but with auto-context loaded). The fallback path is logged
# so you can see at a glance which mode each review used.
bare_flag=""
isolation_note="(no --bare: CLAUDE.md will auto-load — set ANTHROPIC_API_KEY for full isolation)"
if [ -n "${ANTHROPIC_API_KEY:-}" ]; then
    bare_flag="--bare"
    isolation_note="(--bare: CLAUDE.md / DEV_LOG / memory / skills NOT auto-loaded)"
fi

echo "[ai-review] $mode mode, reviewing $n_files file(s) (base=${base:0:10} head=${local_sha:0:10})" >&2
echo "[ai-review] $isolation_note" >&2
echo "[ai-review] --model sonnet for cross-model objectivity; budget cap \$0.50" >&2
echo "[ai-review] (30-90s; bypass with SKIP_AI_REVIEW=1 or --no-verify)" >&2

# --bare           : (conditional) no auto-context
# --model sonnet   : cross-model review (author likely on Opus)
# --print          : non-interactive
# --permission-mode bypassPermissions : allow Bash(git) and Read without prompting
# --max-budget-usd : hard cap to defang runaway reviews
review_output="$(claude --print \
    $bare_flag \
    --model sonnet \
    --permission-mode bypassPermissions \
    --max-budget-usd 0.50 \
    "$review_prompt" 2>&1)"
rc=$?

# Always log the review, even if it errored, for later audit.
log_dir="$(git rev-parse --show-toplevel 2>/dev/null || pwd)/.ai-review-log"
mkdir -p "$log_dir" 2>/dev/null || true
ts="$(date -u +%Y%m%dT%H%M%SZ)"
log_file="${log_dir}/${ts}-${base:0:10}-${local_sha:0:10}-${mode}.txt"
{
    echo "# ai-review log"
    echo "# timestamp:  $(date -u +%Y-%m-%dT%H:%M:%SZ)"
    echo "# base:       $base"
    echo "# head:       $local_sha"
    echo "# mode:       $mode"
    echo "# n_files:    $n_files"
    echo "# shortstat:  $actual_shortstat"
    echo "# isolation:  ${bare_flag:-none} ($isolation_note)"
    echo "# reviewer:   --model sonnet"
    echo "# rc:         $rc"
    echo "# bypass:     SKIP_AI_REVIEW=1 git push  |  git push --no-verify"
    echo "# ---"
    printf '%s\n' "$review_output"
} > "$log_file" 2>/dev/null || true

if [ "$rc" -ne 0 ]; then
    # Tool/network failure: fail-OPEN so a broken CLI doesn't make
    # push impossible. The user explicitly set up this gate; they
    # know to retry once their connection is back.
    echo "[ai-review] claude exited with $rc, allowing push (treat as tool failure, not safety signal)." >&2
    printf '%s\n' "$review_output" | sed 's/^/[ai-review]   /' | head -20 >&2
    echo "[ai-review] full output: $log_file" >&2
    exit 0
fi

echo "" >&2
printf '%s\n' "$review_output" >&2
echo "" >&2
echo "[ai-review] full log: $log_file" >&2

# Hard requirement: DIFF-SUMMARY line must be present. Without it we
# cannot prove the model read the diff.
if ! printf '%s\n' "$review_output" | grep -qE '^DIFF-SUMMARY:'; then
    echo "[ai-review] BLOCK: review output has no DIFF-SUMMARY line." >&2
    echo "[ai-review] interpretation: reviewer did not engage with the diff." >&2
    echo "[ai-review] override with SKIP_AI_REVIEW=1 git push ... if you've confirmed by hand." >&2
    exit 1
fi

# Hard requirement: VERDICT line must be present (fail-CLOSE).
if printf '%s\n' "$review_output" | grep -qiE '^VERDICT:[[:space:]]*block'; then
    echo "[ai-review] verdict: BLOCK. push aborted." >&2
    echo "[ai-review] override: SKIP_AI_REVIEW=1 git push ... | git push --no-verify ..." >&2
    exit 1
fi

if printf '%s\n' "$review_output" | grep -qiE '^VERDICT:[[:space:]]*pass'; then
    # Sanity: warn if the model's DIFF-SUMMARY doesn't match what we
    # know is the real shortstat. Don't block — phrasing can drift —
    # but log loudly so systematic drift is observable.
    claimed_summary="$(printf '%s\n' "$review_output" | grep -E '^DIFF-SUMMARY:' | head -1 | sed 's/^DIFF-SUMMARY:[[:space:]]*//')"
    if [ -n "$actual_shortstat" ] && [ "$claimed_summary" != "$actual_shortstat" ] \
            && [ "$claimed_summary" != "<empty>" ]; then
        echo "[ai-review] note: claimed DIFF-SUMMARY differs from actual." >&2
        echo "[ai-review]   claimed: $claimed_summary" >&2
        echo "[ai-review]   actual:  $actual_shortstat" >&2
        echo "[ai-review] (not blocking; phrasing drift is expected, but flagged in the log.)" >&2
    fi
    echo "[ai-review] verdict: PASS." >&2
    exit 0
fi

# No verdict line at all — fail-CLOSE.
echo "[ai-review] BLOCK: review output has no VERDICT: line." >&2
echo "[ai-review] interpretation: reviewer did not deliver a decision; silence is not safety." >&2
echo "[ai-review] override with SKIP_AI_REVIEW=1 git push ... if you've confirmed by hand." >&2
exit 1
